<UserControl x:Class="ManifestDownloaderGUI.ManifestLibraryTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:ManifestDownloaderGUI.Controls"
             xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <UserControl.Resources>
        <Style TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="4" Padding="0,5">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1E2A3F"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2A3B5A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="MainGrid">
                            <Border x:Name="Border" 
                                    Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    CornerRadius="6"/>
                            <ToggleButton x:Name="ToggleButton" 
                                          Grid.ColumnSpan="2" 
                                          Background="Transparent" 
                                          BorderThickness="0" 
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Focusable="false">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent">
                                            <TextBlock Text="▾" 
                                                       VerticalAlignment="Center" 
                                                       HorizontalAlignment="Right" 
                                                       Margin="0,0,15,0" 
                                                       Foreground="{StaticResource TextBrush}" 
                                                       Opacity="0.5"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" 
                                              IsHitTestVisible="False" 
                                              Content="{TemplateBinding SelectionBoxItem}" 
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" 
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" 
                                              Margin="{TemplateBinding Padding}" 
                                              VerticalAlignment="Center"/>
                            <Popup x:Name="Popup" 
                                   Placement="Bottom" 
                                   IsOpen="{TemplateBinding IsDropDownOpen}" 
                                   AllowsTransparency="True" 
                                   Focusable="False" 
                                   PopupAnimation="Slide">
                                <Border x:Name="DropDownBorder" 
                                        Background="{StaticResource SurfaceBrush}" 
                                        BorderBrush="{StaticResource BorderBrush}" 
                                        BorderThickness="1" 
                                        CornerRadius="6"
                                        MinWidth="{Binding ActualWidth, ElementName=MainGrid}" 
                                        MaxHeight="300"
                                        Margin="0,2,0,0">
                                    <ScrollViewer SnapsToDevicePixels="True" VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#4A90E2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1E2A3F"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2A3B5A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}"/>
        </Style>

        <Style TargetType="Expander">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition x:Name="ContentRow" Height="0"/>
                            </Grid.RowDefinitions>
                            
                            <ToggleButton x:Name="HeaderSite"
                                          Grid.Row="0"
                                          Content="{TemplateBinding Header}"
                                          ContentTemplate="{TemplateBinding HeaderTemplate}"
                                          ContentStringFormat="{TemplateBinding HeaderStringFormat}"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Cursor="Hand">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="HeaderBorder" 
                                                Background="{StaticResource SurfaceBrush}" 
                                                BorderBrush="{StaticResource BorderBrush}" 
                                                BorderThickness="1" 
                                                CornerRadius="8"
                                                Padding="20,15">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0" 
                                                                  VerticalAlignment="Center"
                                                                  RecognizesAccessKey="True"/>
                                                <TextBlock x:Name="Arrow" 
                                                           Grid.Column="1" 
                                                           Text="▾" 
                                                           FontSize="14" 
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource TextBrush}"
                                                           Opacity="0.7"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="HeaderBorder" Property="BorderBrush" Value="#4A90E2"/>
                                            </Trigger>
                                            <DataTrigger Binding="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                                <Setter TargetName="Arrow" Property="Text" Value="▴"/>
                                                <Setter TargetName="HeaderBorder" Property="CornerRadius" Value="8,8,0,0"/>
                                                <Setter TargetName="HeaderBorder" Property="BorderThickness" Value="1,1,1,0"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Border x:Name="ContentBorder" 
                                    Grid.Row="1" 
                                    Background="Transparent" 
                                    BorderBrush="{StaticResource BorderBrush}" 
                                    BorderThickness="1,0,1,1" 
                                    CornerRadius="0,0,8,8"
                                    Margin="5,0,5,0"
                                    Visibility="Collapsed">
                                <ContentPresenter Margin="0,5"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ContentRow" Property="Height" Value="Auto"/>
                                <Setter TargetName="ContentBorder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <!-- Main content area -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="25,20" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Manifest Library" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                    <Button Grid.Column="1" x:Name="RefreshBtn" Content="Refresh" 
                            Click="RefreshBtn_Click"
                            Padding="25,12"
                            Height="45"
                            FontSize="14"
                            FontWeight="SemiBold"/>
                </Grid>
            </Border>

            <!-- Main Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="{StaticResource BackgroundBrush}">
                <StackPanel Margin="40,30" MaxWidth="700">
                    <!-- Manifest Selection -->
                    <StackPanel Margin="0,0,0,35">
                        <Label Content="Select Manifest" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,20"/>
                        <StackPanel>
                            <!-- Server Selection -->
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Label Grid.Column="0" Content="Server:" VerticalAlignment="Center" Margin="0,0,15,0" FontSize="14"/>
                                <ComboBox x:Name="ServerCombo" Grid.Column="1" 
                                          SelectionChanged="ServerCombo_SelectionChanged" 
                                          Height="50"
                                          FontSize="15"
                                          Padding="20,0"
                                          VerticalContentAlignment="Center"/>
                            </Grid>
                            <!-- Patch and Manifest Selection -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Label Grid.Column="0" Content="Patch:" VerticalAlignment="Center" Margin="0,0,15,0" FontSize="14"/>
                                <ComboBox x:Name="PatchCombo" Grid.Column="1" 
                                          SelectionChanged="PatchCombo_SelectionChanged" 
                                          Height="50"
                                          FontSize="15"
                                          Padding="20,0"
                                          VerticalContentAlignment="Center"/>
                                <Label Grid.Column="3" Content="Manifest:" VerticalAlignment="Center" Margin="15,0,15,0" FontSize="14"/>
                                <ComboBox x:Name="ManifestCombo" Grid.Column="4" 
                                          SelectionChanged="ManifestCombo_SelectionChanged"
                                          Height="50"
                                          FontSize="15"
                                          Padding="20,0,50,0"
                                          VerticalContentAlignment="Center"/>
                                <Button Grid.Column="4" x:Name="DeleteManifestBtn" 
                                        Content="🗑" 
                                        Click="DeleteManifestBtn_Click"
                                        Width="40" Height="40"
                                        HorizontalAlignment="Right"
                                        Margin="0,0,5,0"
                                        Background="Transparent"
                                        Foreground="#D32F2F"
                                        BorderThickness="0"
                                        FontSize="18"
                                        ToolTip="Delete selected manifest file"
                                        Visibility="Collapsed"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                    
                    <!-- Output Settings -->
                    <StackPanel Margin="0,0,0,35">
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="Output Path:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14"/>
                            <controls:InfoTooltip Grid.Column="1" 
                                TooltipText="Specify output path. Default is 'output'. Files will be downloaded to this directory."/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="OutputPath" Grid.Column="0" 
                                     Text="output"
                                     Margin="0,0,15,0"
                                     Height="50"
                                     FontSize="15"
                                     Padding="20,0"
                                     VerticalContentAlignment="Center"/>
                            <Button Grid.Column="1" Content="Browse..." 
                                    Click="BrowseBtn_Click"
                                    Padding="25,0"
                                    Height="50"
                                    FontSize="14"
                                    FontWeight="SemiBold"/>
                        </Grid>
                    </StackPanel>
                    
                    <!-- File Filters -->
                    <StackPanel Margin="0,0,0,35">
                        <Label Content="File Filters" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,20"/>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="Filter (regex):" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14"/>
                            <controls:InfoTooltip Grid.Column="1" 
                                TooltipText="Download only files whose full name matches this regex pattern.&#x0a;Example: 'Zeri.wad.client' to download only Zeri's files.&#x0a;Case-insensitive matching."/>
                        </Grid>
                        <controls:WatermarkTextBox x:Name="FilterInput" 
                                                    Watermark="e.g., Zeri.wad.client"
                                                    Margin="0,0,0,20"
                                                    Height="50"
                                                    FontSize="15"
                                                    Padding="20,0"
                                                    VerticalContentAlignment="Center"/>
                        
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="Unfilter (regex):" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14"/>
                            <controls:InfoTooltip Grid.Column="1" 
                                TooltipText="Download only files whose full name does NOT match this regex pattern.&#x0a;Useful to exclude certain files. Case-insensitive matching."/>
                        </Grid>
                        <controls:WatermarkTextBox x:Name="UnfilterInput" 
                                                     Watermark="e.g., en_US"
                                                     Height="50"
                                                     FontSize="15"
                                                     Padding="20,0"
                                                     VerticalContentAlignment="Center"/>
                    </StackPanel>
                    
                    <!-- Language Settings -->
                    <StackPanel Margin="0,0,0,35">
                        <Label Content="Language Settings" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,20"/>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="Languages:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14"/>
                            <controls:InfoTooltip Grid.Column="1" 
                                TooltipText="Provide a list of languages to download.&#x0a;Will ONLY download files that match any of these languages.&#x0a;Separate multiple languages with spaces (e.g., en_US fr_FR).&#x0a;Use 'Include Neutral' to also download language-neutral files."/>
                        </Grid>
                        <controls:WatermarkTextBox x:Name="LanguagesInput" 
                                                     Watermark="e.g., en_US fr_FR de_DE"
                                                     Margin="0,0,0,20"
                                                     Height="50"
                                                     FontSize="15"
                                                     Padding="20,0"
                                                     VerticalContentAlignment="Center"/>
                        
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="IncludeNeutral" Grid.Column="0" 
                                      Content="Include Neutral Files"
                                      VerticalAlignment="Center"
                                      Margin="0,0,10,0"
                                      FontSize="14"/>
                            <controls:InfoTooltip Grid.Column="1" 
                                TooltipText="When languages are specified, also download language-neutral files.&#x0a;Language-neutral files are not specific to any locale."/>
                        </Grid>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="NoLangs" Grid.Column="0" 
                                      Content="No Languages (Neutral Only)"
                                      VerticalAlignment="Center"
                                      Margin="0,0,10,0"
                                      FontSize="14"/>
                            <controls:InfoTooltip Grid.Column="1" 
                                TooltipText="Will ONLY download language-neutral files.&#x0a;No locale-specific files will be downloaded."/>
                        </Grid>
                    </StackPanel>
                    
                    <!-- Advanced Options -->
                    <StackPanel Margin="0,0,0,40">
                        <Label Content="Advanced Options" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,20"/>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="Download Threads:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14"/>
                            <controls:InfoTooltip Grid.Column="1" 
                                TooltipText="Specify amount of download threads.&#x0a;More threads = faster download, but more bandwidth usage.&#x0a;Default is 1."/>
                        </Grid>
                        <TextBox x:Name="ThreadsSpin" Text="1" Margin="0,0,0,20" Height="50" FontSize="15" Padding="20,0" VerticalContentAlignment="Center"/>
                        
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="Bundle Base URL:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14"/>
                            <controls:InfoTooltip Grid.Column="1" 
                                TooltipText="Provide a different base bundle URL.&#x0a;Can also be a local filesystem path.&#x0a;Default is 'https://lol.dyn.riotcdn.net/channels/public/bundles'.&#x0a;Leave empty to use default."/>
                        </Grid>
                        <controls:WatermarkTextBox x:Name="BundleInput" 
                                                     Watermark="Leave empty for default"
                                                     Margin="0,0,0,20"
                                                     Height="50"
                                                     FontSize="15"
                                                     Padding="20,0"
                                                     VerticalContentAlignment="Center"/>
                        
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="VerifyOnly" Grid.Column="0" 
                                      Content="Verify Only"
                                      VerticalAlignment="Center"
                                      Margin="0,0,10,0"
                                      FontSize="14"/>
                            <controls:InfoTooltip Grid.Column="1" 
                                TooltipText="Check files only and print results, but don't update files on disk.&#x0a;Useful to verify existing files without downloading."/>
                        </Grid>
                        
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="ExistingOnly" Grid.Column="0" 
                                      Content="Existing Files Only"
                                      VerticalAlignment="Center"
                                      Margin="0,0,10,0"
                                      FontSize="14"/>
                            <controls:InfoTooltip Grid.Column="1" 
                                TooltipText="Only operate on existing files.&#x0a;Non-existent files are ignored / not created."/>
                        </Grid>
                        
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="SkipExisting" Grid.Column="0" 
                                      Content="Skip Existing Files"
                                      VerticalAlignment="Center"
                                      Margin="0,0,10,0"
                                      FontSize="14"/>
                            <controls:InfoTooltip Grid.Column="1" 
                                TooltipText="By default, all existing files are verified and overwritten if incorrect.&#x0a;With this option, existing files will not be checked if their file size matches the expected one."/>
                        </Grid>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="Verbosity Level:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14"/>
                            <controls:InfoTooltip Grid.Column="1" 
                                TooltipText="Increases verbosity level.&#x0a;Higher values = more detailed output.&#x0a;0 = minimal, 3 = very detailed."/>
                        </Grid>
                        <TextBox x:Name="VerbositySpin" Text="0" Height="50" FontSize="15" Padding="20,0" VerticalContentAlignment="Center"/>
                    </StackPanel>
                    
                    
                    <!-- Manage Local Manifests -->
                    <Expander x:Name="ManageManifestsExpander" IsExpanded="False" Margin="0,0,0,35">
                        <Expander.Header>
                            <TextBlock Text="Manage Local Manifests" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                        </Expander.Header>
                        <Border Padding="5,0,5,5">
                            <Grid>
                                <ListView x:Name="AllManifestsList" MaxHeight="300" Background="Transparent" BorderThickness="0" Margin="0" HorizontalContentAlignment="Stretch">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="10,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Margin="10,0"/>
                                                <Button Grid.Column="1" Content="🗑" 
                                                        Click="DeleteManifestFromList_Click" 
                                                        Tag="{Binding}"
                                                        Width="35" Height="35"
                                                        Background="Transparent" 
                                                        Foreground="#D32F2F" 
                                                        BorderThickness="0" 
                                                        FontSize="16" 
                                                        Cursor="Hand"
                                                        ToolTip="Delete this manifest">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#33D32F2F"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                
                                <StackPanel x:Name="NoManifestsLabel" Visibility="Collapsed" Margin="0,40" HorizontalAlignment="Center">
                                    <TextBlock Text="📁" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10" Opacity="0.3"/>
                                    <TextBlock Text="No local manifests found" 
                                               Foreground="{StaticResource TextSecondaryBrush}" 
                                               FontSize="14"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Expander>
                    
                    <!-- Download Buttons -->
                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Button x:Name="DownloadBtn" 
                                Grid.Column="0"
                                Content="Start Download" 
                                Click="DownloadBtn_Click"
                                IsEnabled="False"
                                Height="60"
                                FontSize="18"
                                FontWeight="Bold"
                                Padding="40,0"
                                HorizontalAlignment="Stretch"/>
                        
                        <Button x:Name="StopDownloadBtn" 
                                Grid.Column="2"
                                Content="Stop Download" 
                                Click="StopDownloadBtn_Click"
                                IsEnabled="False"
                                Height="60"
                                FontSize="18"
                                FontWeight="Bold"
                                Padding="40,0"
                                HorizontalAlignment="Stretch"
                                Background="#D32F2F"
                                Foreground="White"/>
                    </Grid>
                    
                    <!-- Progress Bar -->
                    <ProgressBar x:Name="ProgressBar" 
                                 IsIndeterminate="True" 
                                 Visibility="Collapsed"
                                 Height="6"
                                 Margin="0,25,0,0"/>
                    
                    <!-- Show Log Button -->
                    <Button x:Name="ShowLogBtn" 
                            Content="Show Download Log" 
                            Click="ShowLogBtn_Click"
                            Height="45"
                            FontSize="14"
                            Margin="0,20,0,0"
                            HorizontalAlignment="Left"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
        
        <!-- Download Log Panel - Overlay at bottom -->
        <DockPanel x:Name="LogPanel" 
                   Visibility="Collapsed"
                   LastChildFill="False"
                   VerticalAlignment="Bottom">
            <Border DockPanel.Dock="Top"
                    Background="{StaticResource SurfaceBrush}" 
                    BorderBrush="{StaticResource BorderBrush}" 
                    BorderThickness="0,1,0,0"
                    MinHeight="200"
                    MaxHeight="600">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="300"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Log Header -->
                    <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="Download Log" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Padding="25,20,25,15"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button x:Name="ClearLogBtn" 
                                        Content="Clear Log" 
                                        Click="ClearLogBtn_Click"
                                        Padding="15,5"
                                        Margin="5,10"
                                        Height="35"
                                        Background="Transparent"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        Foreground="{StaticResource TextSecondaryBrush}"/>
                                <Button Content="✕" 
                                        Click="CloseLogBtn_Click"
                                        Width="40"
                                        Height="40"
                                        Margin="10"
                                        FontSize="18"
                                        FontWeight="Bold"
                                        Background="Transparent"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        ToolTip="Close log">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" 
                                                                CornerRadius="4"
                                                                Padding="5">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#1E2A3F"/>
                                                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <!-- Log Content -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <TextBox x:Name="LogOutput" 
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 Background="{StaticResource BackgroundBrush}"
                                 Foreground="{StaticResource TextBrush}"
                                 BorderThickness="0"
                                 Padding="25,15"
                                 FontFamily="Consolas"
                                 FontSize="12"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </DockPanel>
    </Grid>
</UserControl>
