<UserControl x:Class="ManifestDownloaderGUI.ManifestDownloaderTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:ManifestDownloaderGUI.Controls">
    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="25,20" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="Download Manifest from GitHub" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" x:Name="SettingsBtn" Content="⚙ Settings" 
                        Click="SettingsBtn_Click"
                        Padding="20,12"
                        Height="45"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Margin="0,0,10,0"
                        ToolTip="Configure GitHub token to avoid rate limiting"/>
                <Button Grid.Column="2" x:Name="RefreshBtn" Content="Check for New Patches" 
                        Click="RefreshBtn_Click"
                        Padding="25,12"
                        Height="45"
                        FontSize="14"
                        FontWeight="SemiBold"
                        ToolTip="Fetch latest patches from GitHub API and update the list"/>
            </Grid>
        </Border>
        
        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="{StaticResource BackgroundBrush}">
            <StackPanel Margin="40,30" MaxWidth="600">
                <!-- Server Selection -->
                <StackPanel Margin="0,0,0,30">
                    <Label Content="Server" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,12"/>
                    <ComboBox x:Name="ServerCombo" 
                              SelectionChanged="ServerCombo_SelectionChanged"
                              Height="50"
                              FontSize="15"
                              Padding="20,0"
                              VerticalContentAlignment="Center"/>
                </StackPanel>
                
                <!-- Patch Selection -->
                <StackPanel Margin="0,0,0,30">
                    <Label Content="Patch Version" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,12"/>
                    <ComboBox x:Name="PatchCombo" 
                              SelectionChanged="PatchCombo_SelectionChanged"
                              Height="50"
                              FontSize="15"
                              Padding="20,0"
                              VerticalContentAlignment="Center"/>
                </StackPanel>
                
                <!-- Manifest Selection -->
                <StackPanel Margin="0,0,0,40">
                    <Label Content="Manifest" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,12"/>
                    <ComboBox x:Name="ManifestCombo"
                              Height="50"
                              FontSize="15"
                              Padding="20,0"
                              VerticalContentAlignment="Center"/>
                </StackPanel>
                
                <!-- Download Button -->
                <Button x:Name="DownloadBtn" 
                        Content="Download Manifest" 
                        Click="DownloadBtn_Click"
                        IsEnabled="False"
                        Height="55"
                        FontSize="16"
                        FontWeight="Bold"
                        Padding="30,0"
                        HorizontalAlignment="Stretch"/>
                
                <!-- Progress Bar -->
                <ProgressBar x:Name="ProgressBar" 
                             IsIndeterminate="True" 
                             Visibility="Collapsed"
                             Height="6"
                             Margin="0,25,0,0"/>
                
                <!-- Status Label -->
                <TextBlock x:Name="StatusLabel" 
                           TextWrapping="Wrap"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="14"
                           Margin="0,20,0,0"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
