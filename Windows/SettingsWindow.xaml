<Window x:Class="ManifestDownloaderGUI.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings - Configuration &amp; Maintenance" Height="650" Width="800"
        Icon="/unnamed.ico"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextBrush}"
        ResizeMode="NoResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="30,25" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <TextBlock Text="⚙️ GitHub Settings" FontSize="26" FontWeight="Bold" 
                       Foreground="{StaticResource TextBrush}"/>
        </Border>
        
        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="{StaticResource BackgroundBrush}">
            <StackPanel Margin="40,30">
                <!-- Info Card -->
                <Border Background="{StaticResource SurfaceBrush}" 
                        BorderBrush="{StaticResource BorderBrush}" 
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="25"
                        Margin="0,0,0,30">
                    <StackPanel>
                        <TextBlock Text="📈 Increase Your Rate Limit" 
                                  FontSize="16" FontWeight="Bold" 
                                  Foreground="{StaticResource PrimaryBrush}" 
                                  Margin="0,0,0,10"/>
                        <TextBlock TextWrapping="Wrap" 
                                  Foreground="{StaticResource TextBrush}" 
                                  FontSize="14" 
                                  LineHeight="22">
                            Configure your GitHub Personal Access Token to increase your API rate limit from <Run Foreground="{StaticResource PrimaryBrush}" FontWeight="Bold">60</Run> to <Run Foreground="{StaticResource PrimaryBrush}" FontWeight="Bold">5000</Run> requests per hour.
                        </TextBlock>
                    </StackPanel>
                </Border>
                
                <!-- Instructions Card -->
                <Border Background="{StaticResource SurfaceBrush}" 
                        BorderBrush="{StaticResource BorderBrush}" 
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="25"
                        Margin="0,0,0,30">
                    <StackPanel>
                        <TextBlock Text="📝 How to create a token:" 
                                  FontSize="15" FontWeight="SemiBold" 
                                  Foreground="{StaticResource TextBrush}" 
                                  Margin="0,0,0,15"/>
                        <TextBlock TextWrapping="Wrap" 
                                  Foreground="{StaticResource TextSecondaryBrush}" 
                                  FontSize="13" 
                                  LineHeight="20">
                            <Run Text="1. "/><Run FontWeight="SemiBold">Go to</Run> GitHub → Settings → Developer settings → Personal access tokens → Tokens (classic)<LineBreak/>
                            <Run Text="2. "/><Run FontWeight="SemiBold">Click</Run> "Generate new token (classic)"<LineBreak/>
                            <Run Text="3. "/><Run FontWeight="SemiBold">Give it a name</Run> (e.g., "ManifestDownloader")<LineBreak/>
                            <Run Text="4. "/><Run FontWeight="SemiBold">Select scope:</Run> Only check "public_repo" or no scopes needed for public repositories<LineBreak/>
                            <Run Text="5. "/><Run FontWeight="SemiBold">Click</Run> "Generate token" and copy it
                        </TextBlock>
                    </StackPanel>
                </Border>
                
                <!-- Token Input Section -->
                <StackPanel Margin="0,0,0,25">
                    <Label Content="GitHub Personal Access Token" 
                          FontSize="15" FontWeight="SemiBold" 
                          Foreground="{StaticResource TextBrush}" 
                          Margin="0,0,0,8"/>
                    
                    <TextBlock Text="Paste your token below:" 
                              TextWrapping="Wrap" 
                              Foreground="{StaticResource TextSecondaryBrush}" 
                              FontSize="12" 
                              Margin="0,0,0,12"/>
                    
                    <Border Background="{StaticResource SurfaceBrush}" 
                            BorderBrush="{StaticResource BorderBrush}" 
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="3">
                        <PasswordBox x:Name="TokenInput" 
                                    Height="50"
                                    FontSize="14"
                                    Padding="15,0"
                                    VerticalContentAlignment="Center"
                                    BorderThickness="0"
                                    Background="Transparent"
                                    ToolTip="Enter your GitHub Personal Access Token here"/>
                    </Border>
                    
                    <CheckBox x:Name="ShowToken" 
                             Content="👁️ Show token"
                             Foreground="{StaticResource TextBrush}"
                             Checked="ShowToken_Checked"
                             Unchecked="ShowToken_Unchecked"
                             Margin="0,15,0,0"/>
                </StackPanel>
                
                <!-- Status Card -->
                <Border Background="{StaticResource SurfaceBrush}" 
                        BorderBrush="{StaticResource BorderBrush}" 
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20">
                    <TextBlock x:Name="TokenStatus" 
                              TextWrapping="Wrap"
                              Foreground="{StaticResource TextSecondaryBrush}"
                              FontSize="13"
                              LineHeight="20"/>
                </Border>
                
                <!-- Maintenance Section -->
                <TextBlock Text="🛠️ Maintenance" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,15"/>
                <Border Background="{StaticResource SurfaceBrush}" 
                        BorderBrush="{StaticResource BorderBrush}" 
                        BorderThickness="1" 
                        CornerRadius="8" 
                        Padding="25">
                    <StackPanel>
                        <TextBlock Text="Hard Refresh / Reset Cache" 
                                  FontSize="15" FontWeight="SemiBold" 
                                  Foreground="{StaticResource TextBrush}" 
                                  Margin="0,0,0,10"/>
                        <TextBlock Text="If you're having trouble with missing servers or patches, a hard refresh will clear all cached data and force the app to reload everything from GitHub." 
                                  TextWrapping="Wrap" 
                                  Foreground="{StaticResource TextSecondaryBrush}" 
                                  FontSize="13" 
                                  Margin="0,0,0,20"
                                  LineHeight="20"/>
                        <Button x:Name="HardRefreshBtn" 
                                Content="♻️ Perform Hard Refresh" 
                                Click="HardRefreshBtn_Click"
                                Padding="25,12"
                                Height="45"
                                FontSize="14"
                                FontWeight="SemiBold"
                                HorizontalAlignment="Left"
                                Background="#D32F2F"
                                Foreground="White"
                                BorderThickness="0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        
        <!-- Footer with Buttons -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" Padding="30,20" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="1" Content="Clear Token" 
                        Click="ClearBtn_Click"
                        Padding="25,12"
                        Height="45"
                        FontSize="14"
                        Margin="0,0,12,0"/>
                <Button Grid.Column="2" Content="💾 Save" 
                        Click="SaveBtn_Click"
                        Padding="35,12"
                        Height="45"
                        FontSize="14"
                        FontWeight="SemiBold"/>
            </Grid>
        </Border>
    </Grid>
</Window>

