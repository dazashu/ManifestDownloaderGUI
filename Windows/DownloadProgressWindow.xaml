<Window x:Class="ManifestDownloaderGUI.Windows.DownloadProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Downloading ManifestDownloader"
        Width="500"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Border Background="{StaticResource BackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Margin="12">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.6" BlurRadius="25" ShadowDepth="0"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header bar -->
            <Border Grid.Row="0"
                    x:Name="HeaderBar"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="12,12,0,0"
                    Padding="25,18"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="HeaderBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="⬇️"
                               FontSize="22"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"/>

                    <TextBlock Grid.Column="1"
                               x:Name="HeaderText"
                               Text="Downloading ManifestDownloader…"
                               FontSize="17"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                </Grid>
            </Border>

            <!-- Progress body -->
            <StackPanel Grid.Row="1" Margin="30,25,30,20">
                <ProgressBar x:Name="Progress"
                             Height="10"
                             Minimum="0"
                             Maximum="100"
                             Value="0"/>

                <TextBlock x:Name="StatusText"
                           Text="Starting…"
                           FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,12,0,0"/>
            </StackPanel>

            <!-- Button row -->
            <Border Grid.Row="2"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="0,0,12,12"
                    Padding="25,18"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0">
                <Button x:Name="CloseBtn"
                        Content="Cancel"
                        Height="40"
                        MinWidth="120"
                        Padding="22,0"
                        FontSize="14"
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        Foreground="{StaticResource TextBrush}"
                        Click="CloseBtn_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Border>
        </Grid>
    </Border>
</Window>
