<Window x:Class="ManifestDownloaderGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ManifestDownloaderGUI"
        Title="ManifestDownloader GUI" Height="800" Width="1200"
        Icon="/unnamed.ico"
        MinWidth="1000" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">
    <Grid>
        <TabControl x:Name="MainTabControl" Margin="0" BorderThickness="0">
            <TabItem Header="Manifest Downloader" x:Name="DownloaderTab">
                <local:ManifestDownloaderTab x:Name="DownloaderTabContent"/>
            </TabItem>
            <TabItem Header="Manifest Library" x:Name="LibraryTab">
                <local:ManifestLibraryTab x:Name="LibraryTabContent"/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
